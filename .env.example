# Supabase Configuration
# Get these from your Supabase project settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
# Service role key — bypasses RLS; required for admin write operations (add/edit/delete guests)
# Keep this secret — never expose it client-side
SUPABASE_SERVICE_KEY=your-service-role-key

# Admin dashboard password (defaults to "admin" if unset — change this in production)
ADMIN_PASSWORD=your_secure_admin_password

# Resend Email Configuration
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# The "from" address for reminder emails — must be on a verified Resend domain
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Wedding date used client-side for the countdown and server-side in reminder emails (YYYY-MM-DD)
NEXT_PUBLIC_WEDDING_DATE=YYYY-MM-DD
WEDDING_DATE=YYYY-MM-DD
